<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pixerowe Paczki</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Inter, sans-serif;
}

body{
  background:#070A12;
  color:white;
  overflow-x:hidden;
}

/* BACKGROUND EFFECT */
body::before{
  content:"";
  position:fixed;
  width:100%;
  height:100%;
  background:
    radial-gradient(circle at 20% 20%, #7c3aed33, transparent 30%),
    radial-gradient(circle at 80% 80%, #3b82f633, transparent 30%);
  z-index:-1;
}

/* NAV */
nav{
  position:fixed;
  top:0;
  width:100%;
  padding:20px 8%;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:rgba(7,10,18,0.7);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.05);
}

.logo{
  font-weight:700;
  font-size:20px;
  background:linear-gradient(90deg,#8b5cf6,#3b82f6);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

nav a{
  color:white;
  text-decoration:none;
  margin-left:20px;
  opacity:.8;
}

nav a:hover{
  opacity:1;
}

/* HERO */
.hero{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  padding:0 20px;
}

.hero h1{
  font-size:56px;
  font-weight:700;
}

.hero span{
  background:linear-gradient(90deg,#8b5cf6,#3b82f6);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.hero p{
  margin-top:15px;
  color:#b3b3b3;
  max-width:600px;
  margin-left:auto;
  margin-right:auto;
  line-height:1.6;
}

.buttons{
  margin-top:30px;
}

.btn{
  padding:12px 22px;
  border-radius:10px;
  text-decoration:none;
  margin:5px;
  display:inline-block;
}

.primary{
  background:linear-gradient(90deg,#8b5cf6,#3b82f6);
  color:white;
}

.secondary{
  border:1px solid rgba(255,255,255,0.2);
  color:white;
}

/* SECTIONS */
section{
  padding:80px 8%;
}

.title{
  text-align:center;
  font-size:32px;
  margin-bottom:40px;
}

/* CARDS */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:20px;
}

.card{
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.06);
  padding:25px;
  border-radius:16px;
}

.card h3{
  margin-bottom:10px;
}

.card p{
  color:#b3b3b3;
  font-size:14px;
  line-height:1.6;
}

/* DISCORD BOX */
.discord{
  text-align:center;
  padding:50px;
  border-radius:20px;
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(255,255,255,0.06);
}

footer{
  text-align:center;
  padding:30px;
  color:#777;
  border-top:1px solid rgba(255,255,255,0.05);
}

</style>
</head>

<body>

<nav>
  <div class="logo">Pixerowe Paczki</div>
  <div>
    <a href="#oferta">Oferta</a>
    <a href="#cennik">Cennik</a>
    <a href="#dc">Discord</a>
  </div>
</nav>

<div class="hero">
  <div>
    <h1>Tworzymy <span>paczki Minecraft</span></h1>
    <p>Pluginy, paczki PvP, GUI, lobby, grafiki i strony WWW dla serwerów Minecraft.</p>

    <div class="buttons">
      <a class="btn primary" href="#oferta">Zobacz ofertę</a>
      <a class="btn secondary" href="https://discord.gg/NWh3eJnaU">Discord</a>
    </div>
  </div>
</div>

<section id="oferta">

  <div class="title">Oferta</div>

  <div class="grid">

    <div class="card">
      <h3>📦 Paczki</h3>
      <p>
      BattleStages — 30 zł<br>
      KitPvP 2.0 — 30 zł<br>
      Sandy — 30 zł<br>
      Lobby — 40 zł<br>
      Igrzyska — 20 zł<br>
      Duels — 20 zł
      </p>
    </div>

    <div class="card">
      <h3>💻 Pluginy</h3>
      <p>
      Plugin — 20 zł<br>
      Własna paczka — 20+ zł<br>
      Konfiguracje serwerów
      </p>
    </div>

    <div class="card">
      <h3>🎨 Grafika</h3>
      <p>
      Logo — 20 zł<br>
      Miniaturka — 20 zł<br>
      UI / GUI
      </p>
    </div>

    <div class="card">
      <h3>🌐 Strony WWW</h3>
      <p>
      Strona serwera — 40 zł<br>
      Landing page<br>
      Sklep Minecraft
      </p>
    </div>

  </div>

</section>

<section id="cennik">

  <div class="title">Cennik</div>

  <div class="grid">

    <div class="card">
      <h3>Metody płatności</h3>
      <p>PaySafeCard</p>
    </div>

    <div class="card">
      <h3>Zamówienia</h3>
      <p>Ticket na Discordzie</p>
    </div>

    <div class="card">
      <h3>Info</h3>
      <p>Cena zależy od projektu</p>
    </div>

  </div>

</section>

<section id="dc">

  <div class="discord">
    <h2>Dołącz na Discord</h2>
    <p>Kontakt, zamówienia i realizacje</p>
    <br>
    <a class="btn primary" href="https://discord.gg/NWh3eJnaU">Wejdź</a>
  </div>

</section>

<footer>
  © 2026 Pixerowe Paczki
</footer>

</body>
</html>
